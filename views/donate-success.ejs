<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thank You - MailMyWork.io</title>
    <link rel="stylesheet" href="/stylesheets/main.css" />
    <link rel="stylesheet" href="/stylesheets/navbar.css" />
    <!-- SVG Gradient Definition for Logo -->
    <svg style="position: absolute; width: 0; height: 0;">
        <defs>
            <linearGradient id="logoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#1c55d0;stop-opacity:1" />
                <stop offset="100%" style="stop-color:#00f0ff;stop-opacity:1" />
            </linearGradient>
        </defs>
    </svg>
    <style>
        .success-container {
            max-width: 600px;
            margin: 60px auto;
            padding: 40px;
            background: rgba(15, 15, 20, 0.95);
            border: 1px solid rgba(0, 240, 255, 0.3);
            border-radius: 16px;
            text-align: center;
        }

        .success-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #1c55d0, #00f0ff);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 30px;
        }

        .success-icon svg {
            width: 40px;
            height: 40px;
            fill: white;
        }

        .success-title {
            color: #00f0ff;
            font-size: 2.2rem;
            margin-bottom: 20px;
            font-family: 'Rajdhani', sans-serif;
        }

        .success-text {
            color: rgba(255, 255, 255, 0.8);
            margin-bottom: 30px;
            font-size: 1.1rem;
            line-height: 1.6;
        }

        .back-btn {
            display: inline-block;
            padding: 15px 40px;
            background: linear-gradient(135deg, #1c55d0, #00f0ff);
            color: white;
            text-decoration: none;
            border-radius: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
        }

        .back-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(28, 85, 208, 0.3);
        }
    </style>
</head>

<body>
    <!-- Navbar -->
    <header>
        <nav class="navbar">
            <div class="logo">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" fill="none"
                        stroke="url(#logoGradient)" stroke-width="2" />
                    <path d="M22 6l-10 7L2 6" fill="none" stroke="url(#logoGradient)" stroke-width="2" />
                </svg>
                MailMyWork.io
            </div>
            <ul class="nav-links">
                <li><a href="/">Mail My Work</a></li>
                <li><a href="/share">Share Files</a></li>
                <li><a href="/large-file">Large Files</a></li>
                <li><a href="/feedback">Feedback</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/help">Help</a></li>
                <li><a href="/donate" class="active">Support</a></li>
            </ul>
        </nav>
    </header>

    <div class="container">
        <div class="success-container">
            <div class="success-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" />
                </svg>
            </div>
            <h1 class="success-title">Payment Successful!</h1>
            <p class="success-text">Thank you so much for your generous support. Your contribution helps us keep
                MailMyWork running and evolving!</p>
            <a href="/" class="back-btn">Return Home</a>
        </div>
    </div>
</body>

</html>