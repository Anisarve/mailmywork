<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About | MailMyWork.io</title>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-95YQNPYWYM"></script>
  <script src="/javascripts/google_analytics.js"></script>
  <!-- Link main.css since it has base container styles -->
  <link rel="stylesheet" href="/stylesheets/main.css" />
  <link rel="stylesheet" href="/stylesheets/about.css" />
  <link rel="stylesheet" href="/stylesheets/navbar.css" />
  <link rel="manifest" href="/manifest.json" />
</head>

<body>
  <!-- SVG Definitions -->
  <svg style="width:0;height:0;position:absolute;" aria-hidden="true" focusable="false">
    <linearGradient id="logoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#ffffff" />
      <stop offset="100%" stop-color="#00f0ff" />
    </linearGradient>
  </svg>

  <!-- Navbar -->
  <header>
    <nav class="navbar">
      <div class="logo">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" fill="none"
            stroke="url(#logoGradient)" stroke-width="2" />
          <path d="M22 6l-10 7L2 6" fill="none" stroke="url(#logoGradient)" stroke-width="2" />
        </svg>
        MailMyWork.io
      </div>
      <ul class="nav-links">
        <li><a href="/">Mail My Work</a></li>
        <li><a href="/share">Share Files</a></li>
        <li><a href="/large-file">Large Files</a></li>
        <li><a href="/feedback">Feedback</a></li>
        <li><a href="/about" class="active">About</a></li>
        <li><a href="/help">Help</a></li>
      </ul>
      <div class="menu-toggle" id="menu-toggle">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </nav>
  </header>

  <!-- Content -->
  <div class="container">
    <h1 class="title">About Us</h1>

    <div
      style="background:rgba(0,0,0,0.3); padding:30px; border-radius:12px; border:1px solid var(--border-subtle); width:100%;">
      <p style="text-align:center; line-height:1.8; margin-bottom: 2rem; color:var(--text-main); font-size:1.05rem;">
        MailMyWork.io is built to make sending notes, files, and reminders to yourself
        faster than ever. With a clean design and instant self-mailing, you don’t have to
        switch apps or waste time.
      </p>

      <div
        style="height:1px; width:50%; margin:0 auto 2rem; background:linear-gradient(90deg, transparent, var(--accent-cyan), transparent);">
      </div>

      <p style="text-align:center; line-height:1.8; color:var(--text-muted); font-size:1.05rem;">
        Our mission is simple: <strong style="color:var(--text-main);">boost your productivity</strong> by keeping all
        your important stuff
        in your inbox — where you actually check daily.
      </p>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script src="/javascripts/navbar.js"></script>
  <script>
    if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js');
  </script>
</body>

</html>