<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Donate - MailMyWork.io</title>
    <link rel="stylesheet" href="/stylesheets/main.css" />
    <link rel="stylesheet" href="/stylesheets/navbar.css" />
    <link rel="manifest" href="/manifest.json" />
    <!-- SVG Gradient Definition for Logo -->
    <svg style="position: absolute; width: 0; height: 0;">
        <defs>
            <linearGradient id="logoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#1c55d0;stop-opacity:1" />
                <stop offset="100%" style="stop-color:#00f0ff;stop-opacity:1" />
            </linearGradient>
        </defs>
    </svg>
    <style>
        .container {
            opacity: 1 !important;
        }

        .donate-container {
            max-width: 600px;
            margin: 40px auto;
            padding: 30px;
            z-index: 100;
            background: rgba(15, 15, 20, 0.95);
            border: 1px solid rgba(0, 240, 255, 0.3);
            border-radius: 16px;
            text-align: center;
        }

        .donate-title {
            color: #00f0ff;
            font-size: 2rem;
            margin-bottom: 20px;
            font-family: 'Rajdhani', sans-serif;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .donate-desc {
            color: rgba(255, 255, 255, 0.8);
            margin-bottom: 30px;
            line-height: 1.6;
        }

        .amount-selector {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-bottom: 30px;
        }

        .amount-btn {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            padding: 15px;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-size: 1.2rem;
            font-weight: 600;
        }

        .amount-btn:hover {
            border-color: #00f0ff;
            background: rgba(0, 240, 255, 0.05);
        }

        .amount-btn.active {
            background: linear-gradient(135deg, #1c55d0, #00f0ff);
            border-color: transparent;
        }

        .custom-amount {
            margin-bottom: 30px;
        }

        .custom-amount input {
            width: 100%;
            padding: 15px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            color: white;
            font-size: 1.1rem;
            text-align: center;
        }

        .custom-amount input:focus {
            outline: none;
            border-color: #00f0ff;
        }

        .donor-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 30px;
        }

        .donor-info input {
            padding: 15px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            color: white;
            font-size: 1rem;
        }

        .donor-info input:focus {
            outline: none;
            border-color: #00f0ff;
        }

        .donate-btn {
            width: 100%;
            padding: 18px;
            background: linear-gradient(135deg, #1c55d0, #00f0ff);
            border: none;
            border-radius: 10px;
            color: white;
            font-size: 1.2rem;
            font-weight: 700;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
        }

        .donate-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(28, 85, 208, 0.3);
        }

        .donate-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        @media (max-width: 480px) {
            .amount-selector {
                grid-template-columns: 1fr 1fr;
            }

            .donor-info {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <!-- Navbar -->
    <header>
        <nav class="navbar">
            <div class="logo">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" fill="none"
                        stroke="url(#logoGradient)" stroke-width="2" />
                    <path d="M22 6l-10 7L2 6" fill="none" stroke="url(#logoGradient)" stroke-width="2" />
                </svg>
                MailMyWork.io
            </div>
            <ul class="nav-links">
                <li><a href="/">Mail My Work</a></li>
                <li><a href="/share">Share Files</a></li>
                <li><a href="/large-file">Large Files</a></li>
                <li><a href="/feedback">Feedback</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/help">Help</a></li>
                <li><a href="/donate" class="active">Support</a></li>
            </ul>
        </nav>
    </header>

    <div class="container">
        <div class="donate-container">
            <h1 class="donate-title">Support MailMyWork</h1>
            <p class="donate-desc">Your donations help keep the service free and fast for everyone. Every contribution
                counts!</p>

            <div class="amount-selector">
                <button class="amount-btn" data-amount="100">₹100</button>
                <button class="amount-btn active" data-amount="500">₹500</button>
                <button class="amount-btn" data-amount="1000">₹1000</button>
            </div>

            <div class="custom-amount">
                <input type="number" id="customAmount" placeholder="Or enter custom amount (Min. ₹10)" min="10" />
            </div>

            <div class="donor-info">
                <input type="text" id="donorName" placeholder="Your Name (Optional)" />
                <input type="email" id="donorEmail" placeholder="Your Email" required />
            </div>

            <button class="donate-btn" id="donateBtn">Donate Now</button>
        </div>
    </div>

    <script src="/javascripts/donate.js"></script>
</body>

</html>