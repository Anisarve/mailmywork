<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ShareMyWork.io</title>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-95YQNPYWYM"></script>
  <script src="/javascripts/google_analytics.js"></script>
  <!-- Link reuse main.css for consistency since they share structure -->
  <link rel="stylesheet" href="/stylesheets/main.css" />
  <link rel="stylesheet" href="/stylesheets/share.css" />
  <link rel="stylesheet" href="/stylesheets/navbar.css" />
  <link rel="manifest" href="/manifest.json" />
</head>

<body>
  <!-- SVG Definitions -->
  <svg style="width:0;height:0;position:absolute;" aria-hidden="true" focusable="false">
    <linearGradient id="logoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#ffffff" />
      <stop offset="100%" stop-color="#00f0ff" />
    </linearGradient>
  </svg>

  <!-- Navbar -->
  <header>
    <nav class="navbar">
      <div class="logo">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" fill="none"
            stroke="url(#logoGradient)" stroke-width="2" />
          <path d="M22 6l-10 7L2 6" fill="none" stroke="url(#logoGradient)" stroke-width="2" />
        </svg>
        MailMyWork.io
      </div>
      <ul class="nav-links">
        <li><a href="/">Mail My Work</a></li>
        <li><a href="/share">Share Files</a></li>
        <li><a href="/large-file">Large Files</a></li>
        <li><a href="/feedback">Feedback</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/help">Help</a></li>
        <li><a href="/donate">Support</a></li>
      </ul>
      <div class="menu-toggle" id="menu-toggle">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </nav>
  </header>

  <div class="container">
    <h1 class="title">Share Content</h1>

    <!-- Mode Toggle -->
    <div class="mode-toggle">
      <button id="textBtn" class="active">
        <svg viewBox="0 0 24 24">
          <path
            d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" />
        </svg>
        Text
      </button>
      <button id="fileBtn">
        <svg viewBox="0 0 24 24">
          <path d="M9 16h6v-6h4l-7-7-7 7h4zm-4 2h14v2H5z" />
        </svg>
        File
      </button>
      <button id="receive-btn">
        <svg viewBox="0 0 24 24">
          <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" />
        </svg>
        Receive
      </button>
    </div>

    <!-- Dynamic Content -->
    <div id="contentArea" class="content">
      <textarea placeholder="Type or paste your text here..." id="textArea"></textarea>
    </div>

    <div id="uploadList">
    </div>
    <div class="code" id="code"
      style="text-align:center; font-family:'Rajdhani', sans-serif; font-size:1.5rem; letter-spacing:2px; margin-top:1rem; color:var(--accent-cyan);">
    </div>

    <!-- Submit -->
    <button class="submit-btn" id="share-btn">Share</button>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script src="/javascripts/share.js"></script>
  <script src="/javascripts/navbar.js"></script>
  <script src="/javascripts/pwa-share.js"></script>
</body>

</html>